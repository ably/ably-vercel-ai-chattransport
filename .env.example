# ---------------------------------------------------------------------------
# Ably
# ---------------------------------------------------------------------------
# Your Ably API key. The server uses it to mint short-lived token requests
# (/api/token) and to publish the AI stream back over Ably. The browser never
# sees it. Get one at https://ably.com/accounts
ABLY_API_KEY=your-app.key:secret

# Optional fallback clientId used by /api/token when the client doesn't send one.
# DEFAULT_CLIENT_ID=

# Prefix for auto-generated channel names (optional, default: ai:).
# Each fresh visit generates a channel like "<namespace><word-word-word>".
# Pin a specific channel with ?channel=<name> in the URL instead.
# NEXT_PUBLIC_ABLY_CHANNEL_NAMESPACE=ai:

# ---------------------------------------------------------------------------
# AI provider — configure ONE of the following.
# Selection priority (see src/app/api/chat/model.ts): anthropic > gateway > openai
# ---------------------------------------------------------------------------

# Option A: Anthropic — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B: Vercel AI Gateway
# AI_GATEWAY_API_KEY=...
# AI_GATEWAY_MODEL=openai/gpt-4o-mini   # optional, default: openai/gpt-4o-mini

# Option C: OpenAI or any OpenAI-compatible endpoint
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional, custom endpoint
# OPENAI_MODEL=gpt-4o                          # optional, default: gpt-4o
